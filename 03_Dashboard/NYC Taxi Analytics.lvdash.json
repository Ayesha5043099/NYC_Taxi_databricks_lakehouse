{
  "datasets": [
    {
      "name": "4be7d7b2",
      "displayName": "Taxi Trip Insights by Hour Analysis",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "    pickup_hour,\n",
        "    SUM(total_trips) AS total_trips,\n",
        "    ROUND(AVG(avg_fare_usd), 2) AS avg_fare,\n",
        "    ROUND(AVG(avg_duration_mins), 2) AS avg_duration\n",
        "FROM nyc_taxi_project.gold_data.gold_hourly_trips\n",
        "GROUP BY pickup_hour\n",
        "ORDER BY pickup_hour"
      ]
    },
    {
      "name": "a1668c69",
      "displayName": "Payment Method Summary for Taxi Trips and Revenue",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "    payment_label,\n",
        "    SUM(total_trips) AS total_trips,\n",
        "    SUM(total_fare_usd) AS total_revenue,\n",
        "    SUM(total_tips_usd) AS total_tips\n",
        "FROM nyc_taxi_project.gold_data.gold_payment_summary\n",
        "GROUP BY payment_label\n",
        "ORDER BY total_trips DESC"
      ]
    },
